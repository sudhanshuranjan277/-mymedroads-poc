$(document).ready(function () {
    var pathname = window.location.pathname;
    $('#description22 > li > a[href="' + pathname + '"]').parent().addClass('blogLstActv');
 
    $(".close-popup").click(function(){
     
        $(".popup-wrapper").hide();
      });
    
})
$('.gal_innwrp').click(function () {
    var tab_idg = $(this).attr('data-tb');

    $('.gal_innwrp').removeClass('currentGal');
    $('.tab-galcontent').removeClass('currentGal');
    $('.gal_pop_in').fadeIn('gal_pop_inAdd');
    $('.inn_midto').stop().animate({
        'opacity': '1'
    })

    $(this).addClass('currentGal');
    $("#" + tab_idg).addClass('currentGal');
    })
$('.close').click(function () {
    $('.gal_pop_in').fadeOut('gal_pop_inAdd');
    $('.inn_midto').stop().animate({
        'opacity': '0'
    })
});
