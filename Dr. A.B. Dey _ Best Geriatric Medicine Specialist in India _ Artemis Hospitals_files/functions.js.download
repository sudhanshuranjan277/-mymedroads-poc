$('.ArowClose').click(function(){
    $('.BkAppoint').slideUp('slow'); 
});

$('.MngnOpntb').click(function () {
    var tab_img = $(this).attr('data-mg');

    $('.MngnOpntb').removeClass('currentGal');
    $('.tab-galcontent').removeClass('currentGal');
    $('.gal_pop_in').fadeIn('gal_pop_inAdd');
    $('.inn_midto').stop().animate({
        'opacity': '1'
    })

    $(this).addClass('currentGal');
    $("#" + tab_img).addClass('currentGal');
})
$(window).scroll(function () {
    $(window).scrollTop() >= 20 ? $(".blog_mainbkn").addClass("blog_mainbkn_fix") : $(".blog_mainbkn").removeClass("blog_mainbkn_fix")
})
